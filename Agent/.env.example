# StudyQuest 环境变量配置
# 复制此文件为 .env 并填入真实值

# === Anthropic Claude API ===
# LLM_PROVIDER: anthropic(原生) 或 openai(兼容端点，如DeepSeek)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
LLM_PROVIDER=anthropic
ANTHROPIC_BASE_URL=

# === 多模态 OCR（Doubao-Seed-2.0-pro 等视觉模型）===
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=

# === Embedding（独立配置，可走不同端点）===
# 默认回退到 OPENAI_API_KEY / OPENAI_BASE_URL
EMBEDDING_API_KEY=sk-xxxxx
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# === Tavily 联网搜索 ===
TAVILY_API_KEY=tvly-xxxxx

# === Qdrant 向量数据库 ===
# 本地部署（host+port）或云服务（url+api_key）二选一
QDRANT_URL=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=studyquest_knowledge

# === MySQL ===
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=studyquest

# === Flask ===
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# === 文件存储 ===
UPLOAD_DIR=./workspace/uploads
TASK_DIR=./workspace/.agent/tasks
MAX_FILE_SIZE_MB=50

# === RAG 配置 ===
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_SIMILARITY_THRESHOLD=0.65

# === 学习配置 ===
TASK_MIN_MINUTES=20
TASK_MAX_MINUTES=50
SAME_SUBJECT_MAX_MINUTES=90
BREAK_MINUTES=10
WEAK_POINT_DAYS=7
WEAK_POINT_TOP_N=3
